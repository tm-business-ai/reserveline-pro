# ReserveLine Pro settings
APP_NAME=ReserveLine Pro

# true: LINE公式アカウントがなくても動作確認できます
# false: LINE Messaging APIと接続する本番想定モードです
DEMO_MODE=true

# Streamlit管理画面ログイン用です。本番では必ず変更してください。
ADMIN_PASSWORD=change-me

# 本番モードでのみ設定してください。値は絶対にGitHubへ公開しないでください。
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# SQLite DBの保存先
DATABASE_PATH=./data/reserveline.db

# 予約の何時間前にリマインド対象にするか
REMINDER_HOURS_BEFORE=24

# FastAPI起動時にAPSchedulerを動かすか
SCHEDULER_ENABLED=true

# 予約受付ルール
BUSINESS_OPEN_TIME=09:00
BUSINESS_CLOSE_TIME=18:00
BUSINESS_DAYS=mon,tue,wed,thu,fri,sat
BUSINESS_TIMEZONE=Asia/Tokyo
SLOT_INTERVAL_MINUTES=30
MIN_BOOKING_NOTICE_MINUTES=120
MAX_BOOKING_DAYS_AHEAD=30
